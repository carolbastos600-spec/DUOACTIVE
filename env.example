# Servidor
PORT=4174
HOST=0.0.0.0

# URL pública do site.
# Local:
PUBLIC_BASE_URL=http://127.0.0.1:4174
# Produção, depois de apontar o domínio:
# PUBLIC_BASE_URL=https://www.duoactive.com.br

# Mercado Pago
# Copie o Access Token de produção no painel Mercado Pago Developers.
# Nunca coloque essa chave no HTML, CSS ou JS do navegador.
MERCADO_PAGO_ACCESS_TOKEN=APP_USR_SEU_ACCESS_TOKEN_AQUI

# URLs de retorno do checkout.
# Em produção, use:
# CHECKOUT_SUCCESS_URL=https://www.duoactive.com.br/#checkout
# CHECKOUT_PENDING_URL=https://www.duoactive.com.br/#checkout
# CHECKOUT_FAILURE_URL=https://www.duoactive.com.br/#checkout
CHECKOUT_SUCCESS_URL=http://127.0.0.1:4174/#checkout
CHECKOUT_PENDING_URL=http://127.0.0.1:4174/#checkout
CHECKOUT_FAILURE_URL=http://127.0.0.1:4174/#checkout
